{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/docker/Dockerfile.connector-echo"
  },
  "deploy": {
    "startCommand": "/usr/local/bin/elena-connector-echo",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
