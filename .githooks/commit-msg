#!/bin/sh
# Commit-msg: enforce conventional-commit subjects.
#   <type>(<scope>)?(!)?: <subject>
# Allowed types: feat fix chore docs style refactor test perf build ci revert
#
# Bypass: git commit --no-verify, or SKIP_HOOKS=1 git commit ...
# Auto-generated subjects (Merge / Revert / fixup! / squash! / Reapply) pass
# through unchanged.
set -eu

if [ "${SKIP_HOOKS:-0}" = "1" ]; then
    exit 0
fi

msg_file="$1"
subject=$(grep -vE '^\s*(#|$)' "$msg_file" | head -n 1)

if [ -z "$subject" ]; then
    printf '\033[1;31m[commit-msg] empty subject.\033[0m\n'
    exit 1
fi

case "$subject" in
    Merge\ *|Revert\ \"*|fixup!\ *|squash!\ *|Reapply\ *)
        exit 0
        ;;
esac

regex='^(feat|fix|chore|docs|style|refactor|test|perf|build|ci|revert)(\([a-z0-9._/-]+\))?!?: .+'

if ! printf '%s' "$subject" | grep -Eq "$regex"; then
    cat <<'EOF'
[commit-msg] invalid subject.

Required: <type>(<scope>)?(!)?: <subject>

Types:    feat | fix | chore | docs | style | refactor | test
          | perf | build | ci | revert

Examples: feat(gateway): add JWT mint endpoint
          fix(store): app delete pre-check uses i32 for INT4
          docs: refresh CLAUDE.md HTTP surface
          chore!: drop deprecated TenantTier

Bypass: git commit --no-verify (or SKIP_HOOKS=1).
EOF
    exit 1
fi

subject_len=$(printf '%s' "$subject" | wc -c | tr -d ' ')
if [ "$subject_len" -gt 72 ]; then
    printf '\033[1;33m[commit-msg] warning:\033[0m subject is %s chars (>72 recommended).\n' "$subject_len"
fi

exit 0
