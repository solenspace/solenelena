#!/bin/sh
# Pre-commit: enforce the canonical lint pair from CLAUDE.md.
#   cargo fmt --all -- --check
#   cargo clippy --workspace --all-targets -- -D warnings
#
# Bypass: git commit --no-verify, or SKIP_HOOKS=1 git commit ...
# Skips itself when no Rust-affecting files are staged.
set -eu

if [ "${SKIP_HOOKS:-0}" = "1" ]; then
    exit 0
fi

staged=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$staged" ]; then
    exit 0
fi

if ! printf '%s\n' "$staged" | grep -Eq '\.rs$|(^|/)Cargo\.(toml|lock)$|^rustfmt\.toml$|^rust-toolchain\.toml$|^deny\.toml$|^\.cargo/'; then
    exit 0
fi

printf '\033[1;34m[pre-commit]\033[0m cargo fmt --all -- --check\n'
if ! cargo fmt --all -- --check; then
    printf '\n\033[1;31m[pre-commit] formatting failed.\033[0m Fix: cargo fmt --all\n'
    printf 'Bypass: git commit --no-verify (or SKIP_HOOKS=1).\n'
    exit 1
fi

printf '\033[1;34m[pre-commit]\033[0m cargo clippy --workspace --all-targets -- -D warnings\n'
if ! cargo clippy --workspace --all-targets -- -D warnings; then
    printf '\n\033[1;31m[pre-commit] clippy failed.\033[0m\n'
    printf 'Bypass: git commit --no-verify (or SKIP_HOOKS=1).\n'
    exit 1
fi

exit 0
